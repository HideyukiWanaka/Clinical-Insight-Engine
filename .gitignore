# ============================================================
# Clinical Insight Engine — .gitignore
# ============================================================

# ===== 環境変数・シークレット =====
.env
.env.local
.env.*.local
*.env

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
pip-log.txt

# ===== Node.js / Next.js =====
node_modules/
.next/
out/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===== Docker =====
.docker/

# ===== macOS =====
.DS_Store
.AppleDouble
.LSOverride
*.DS_Store

# ===== IDE =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== R =====
.Rhistory
.RData
.Rproj.user/
*.Rproj

# ===== Database =====
*.sqlite
*.db
postgres-data/

# ===== Redis =====
redis-data/
dump.rdb

# ===== ログ =====
*.log
logs/

# ===== テスト =====
.coverage
htmlcov/
.pytest_cache/
coverage.xml

# ===== 臨床データ（絶対にコミットしない） =====
# 万一CSVが混入した場合のセーフガード
*.csv
*.xlsx
*.xls
raw_data/
clinical_data/
