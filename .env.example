# =====================================================
# Clinical Insight Engine — Environment Variables
# Copy this file to .env and fill in all values.
# ⚠ Never commit .env to version control.
# =====================================================


# ─────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────
POSTGRES_DB=cie_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# Async DSN used by SQLAlchemy + asyncpg inside backend container
DATABASE_URL=postgresql+asyncpg://postgres:changeme_strong_password@postgres:5432/cie_db

# Sync DSN used by Alembic migrations (run from host or migration container)
DATABASE_SYNC_URL=postgresql://postgres:changeme_strong_password@localhost:5432/cie_db


# ─────────────────────────────────────────────────────
# Redis (ephemeral clinical data — TTL: max 24h)
# ─────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379/0


# ─────────────────────────────────────────────────────
# FastAPI Backend
# ─────────────────────────────────────────────────────
BACKEND_SECRET_KEY=changeme_at_least_32_chars_random_string

# Internal URL for backend → r-engine communication (docker network)
R_ENGINE_URL=http://r-engine:8001

# CORS allowed origins (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:3000


# ─────────────────────────────────────────────────────
# Anthropic Claude API
# ⚠ Rule: Only column metadata (name, type, missingRate) is sent — NEVER raw data rows
# ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your_key_here...


# ─────────────────────────────────────────────────────
# Google OAuth 2.0 (via NextAuth.js)
# Configure at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret


# ─────────────────────────────────────────────────────
# NextAuth.js (Frontend)
# Generate NEXTAUTH_SECRET: `openssl rand -base64 32`
# ─────────────────────────────────────────────────────
NEXTAUTH_SECRET=changeme_nextauth_secret_base64_32_chars
NEXTAUTH_URL=http://localhost:3000


# ─────────────────────────────────────────────────────
# Google Workspace API (Slides / Docs / Drive)
# Service Account or OAuth token for template injection
# ─────────────────────────────────────────────────────
GOOGLE_WORKSPACE_SA_KEY_PATH=/run/secrets/google_sa_key.json
